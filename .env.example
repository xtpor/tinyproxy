# TinyProxy Docker Environment Variables

# Health check interval in seconds
HEALTH_CHECK_INTERVAL=30

# Proxy port (internal container port)
PROXY_PORT=8888

# Authentication username
AUTH_USER=user

# Password file location (inside container)
PASSWORD_FILE=/data/password.txt

# Note: Password is auto-generated on first run and stored in the volume
# To set a custom password, you can:
# 1. Manually create the password file in the volume
# 2. Or set AUTH_PASSWORD environment variable (not recommended for security)